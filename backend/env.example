# ── MyAnonamouse ─────────────────────────────────────────────────────────────
# Your MAM session cookie. Get this from browser DevTools → Application → Cookies
# Can be provided with or without the "mam_id=" prefix
MAM_COOKIE=mam_id=your_mam_cookie_here

# Base URL for MAM (don't change this unless MAM moves)
MAM_BASE=https://www.myanonamouse.net

# ── qBittorrent ───────────────────────────────────────────────────────────────
# URL of your qBittorrent Web UI (use container name if on same Docker network)
QBITTORRENT_URL=http://qbittorrent:8080

QBITTORRENT_USER=admin
QBITTORRENT_PASS=your_qbittorrent_password

# Path inside qBittorrent where audiobooks will be saved
QBITTORRENT_SAVEPATH=/media/audiobooks

# ── App ───────────────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens — use a long random string
JWT_SECRET=change_this_to_a_long_random_secret

JWT_ALGO=HS256

# Invite code required to register a new account
INVITE_CODE=your_invite_code

# ── Watchlist ─────────────────────────────────────────────────────────────────
# How often (in hours) the app polls MAM for watchlist matches
WATCHLIST_POLL_HOURS=6

# ── Discord (optional) ────────────────────────────────────────────────────────
# Leave blank to disable Discord notifications
DISCORD_WEBHOOK=https://discord.com/api/webhooks/your/webhook/url
